# ==========================================
# Variables de Sécurité & Configuration globale
# ==========================================
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=change-me-in-production

# ==========================================
# Base de données — SQLite (développement, par défaut)
# ==========================================
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# ==========================================
# Base de données — PostgreSQL (production)
# Décommentez et configurez ces lignes pour la production :
# ==========================================
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=bd_cofinance_ci
# DATABASE_USER=cofinanceci
# DATABASE_PASSWORD=cofinanceci123
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==========================================

# WebSockets & Redis (production)
# ==========================================
# REDIS_URL=redis://127.0.0.1:6379/0

# ==========================================
# CORS & Médias
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEDIA_URL=/media/
MEDIA_ROOT=media
